{
  "name": "promptscan",
  "version": "1.3.0",
  "description": "Static analysis for LLM call sites. Find what your prompts cost before you ship them.",
  "type": "module",
  "bin": {
    "promptscan": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schema",
    "wasm"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "build:web": "node web/build.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "llm",
    "prompt",
    "static-analysis",
    "openai",
    "anthropic",
    "tokens",
    "cost",
    "cli"
  ],
  "license": "MIT",
  "author": "joandino",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joandino/promptscan.git"
  },
  "homepage": "https://github.com/joandino/promptscan#readme",
  "bugs": {
    "url": "https://github.com/joandino/promptscan/issues"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "globby": "^14.0.2",
    "js-tiktoken": "^1.0.21",
    "web-tree-sitter": "^0.25.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/path-browserify": "^1.0.3",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1",
    "path-browserify": "^1.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
